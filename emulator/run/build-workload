@dataclass(frozen=True)
class TargetConfig:
    name: str
    arch: str
    abi: str
    cc: str
    cc_flags: tuple[str, ...]
    crt: str | None
    linker_script: str | None
    vlen: int
    use_nix: bool = False
    t1_root: str | None = None


@dataclass
class BuildOptions:
    lmul: int = 1
    len_1d: int = 1000
    use_vf: str | None = None
    asm_only: bool = False
    output: Path | None = None
    build_out_dir: Path | None = None
    dry_run: bool = False
    cli_cflags: list[str] = field(default_factory=list)
    cli_llvm_flags: list[str] = field(default_factory=list)
    cli_opt_flags: list[str] = field(default_factory=list)
    quiet: bool = False


@dataclass
class WorkloadSpec:
    name: str
    base_dir: Path
    manifest_path: Path | None
    entry_mode: str
    entry_symbol: str
    sources: list[Path]
    include_dirs: list[Path] = field(default_factory=list)
    compile_flags: list[str] = field(default_factory=list)
    llvm_flags: list[str] = field(default_factory=list)
    opt_flags: list[str] = field(default_factory=list)
    link_flags: list[str] = field(default_factory=list)
    support: str = "default"
    support_sources: list[Path] = field(default_factory=list)
    crt: str | Path | None = "default"
    linker_script: str | Path | None = "default"
    metadata: dict[str, Any] = field(default_factory=dict)
    target_overrides: dict[str, Any] = field(default_factory=dict)


@dataclass
class BuildResult:
    output: Path | None
    asm_outputs: list[Path]
    ir_outputs: list[Path]
    object_outputs: list[Path]
    build_dir: Path


