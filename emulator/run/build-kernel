#!/bin/bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
RVV_ROOT="${RVV_ROOT:-$(realpath "${SCRIPT_DIR}/..")}"
PREVEC_PASSES="${PREVEC_PASSES:-mem2reg,instcombine,simplifycfg,loop-simplify,lcssa,indvars,loop-rotate,instcombine,simplifycfg}"
FORCED_OPT_PASSES="${FORCED_OPT_PASSES:-default<O3>}"
TSVC_WRAPPER_MARKER="TSVC_EMULATE_WRAPPER"
TSVC_GENERATED_MARKER="TSVC_EMULATE_GENERATED"

usage() {
    echo "Usage: build-kernel <target> <source.c> [options]"
    echo ""
    echo "Targets: spike, gem5, saturn, ara, xiangshan, t1, c910, vicuna, ocelot"
    echo ""
    echo "Options:"
    echo "  --lmul=N       LMUL value (1,2,4,8) [default: 1]"
    echo "  --len=N        LEN_1D array size [default: 1000]"
    echo "  --use-vf=SPEC  Force loop vectorization with LLVM -vplan-use-vf syntax"
    echo "  --output=FILE  Output ELF path"
    echo "  --asm          Generate assembly output"
    echo "  --llvm=FLAGS   Additional LLVM flags"
    echo "  --cflags=FLAGS Additional C flags"
    echo ""
    echo "To run simulations, use run-sim.sh:"
    echo "  ./run-sim.sh <target> <source.c or elf> [--lmul=N] [--len=N] [--use-vf=fixed:4]"
    exit 1
}

die() {
    echo "$*" >&2
    exit 1
}

warn() {
    echo "warning: $*" >&2
}

validate_positive_int() {
    local name="$1"
    local value="$2"
    case "$value" in
        ''|*[!0-9]*)
            die "$name must be a positive integer"
            ;;
    esac
    if [[ "$value" -le 0 ]]; then
        die "$name must be a positive integer"
    fi
}

resolve_opt() {
    local candidates=()
    if [[ -n "${OPT:-}" ]]; then
        candidates+=("${OPT}")
    fi
    if [[ -n "${LLVM_BIN_DIR:-}" ]]; then
        candidates+=("${LLVM_BIN_DIR}/opt")
    fi
    if [[ -n "${LLVM_BUILD_DIR:-}" ]]; then
        candidates+=("${LLVM_BUILD_DIR}/bin/opt" "${LLVM_BUILD_DIR}/opt")
    fi
    candidates+=(
        "${RVV_ROOT}/llvm-build/bin/opt"
        "${RVV_ROOT}/llvm-build/opt"
    )

    local candidate
    for candidate in "${candidates[@]}"; do
        if [[ -x "$candidate" ]]; then
            printf '%s\n' "$candidate"
            return 0
        fi
    done

    if command -v opt >/dev/null 2>&1; then
        command -v opt
        return 0
    fi
    if command -v opt-vplan >/dev/null 2>&1; then
        command -v opt-vplan
        return 0
    fi

    return 1
}

append_split_flags() {
    local raw="$1"
    local var_name="$2"
    if [[ -z "$raw" ]]; then
        return 0
    fi
    local -a parsed=()
    eval "parsed=($raw)"
    local item
    for item in "${parsed[@]}"; do
        eval "$var_name+=(\"\$item\")"
    done
}

compile_to_object() {
    local src="$1"
    local obj="$2"
    "${CC}" "${OBJECT_COMPILE_FLAGS[@]}" -c "$src" -o "$obj"
}

verify_forced_vector_ir() {
    local ir_path="$1"
    local vf_spec="$2"
    local log_path="$3"

    if [[ -f "$log_path" ]]; then
        if grep -Eq 'requested -vplan-use-vf is not available|invalid -vplan-use-vf entry|forced -vplan-use-vf is unsupported' "$log_path"; then
            die "Forced VF optimization was rejected by opt. Log: ${log_path}"
        fi
    fi

    local first_entry="${vf_spec%%,*}"
    if [[ "$first_entry" == "-" || -z "$first_entry" ]]; then
        return 0
    fi

    local vf_kind="${first_entry%%:*}"
    local vf_width="${first_entry#*:}"
    local vector_body_found=0
    local vf_found=0

    if grep -Eq '(^|[[:space:]])vector\.body([:.]|[[:space:]])' "$ir_path"; then
        vector_body_found=1
    fi
    if [[ "$vf_kind" == "fixed" && "$vf_width" == "1" ]]; then
        return 0
    fi
    if [[ "$vf_kind" == "fixed" ]]; then
        if grep -Eq "<${vf_width} x " "$ir_path"; then
            vf_found=1
        fi
    elif [[ "$vf_kind" == "scalable" ]]; then
        if grep -Eq "<vscale x ${vf_width} x " "$ir_path"; then
            vf_found=1
        fi
    fi

    if [[ "$vector_body_found" -ne 1 ]]; then
        warn "Forced VF ${first_entry} did not leave a final vector.body marker in ${ir_path}; continuing because late vector passes may rewrite the loop shape"
    fi
    if [[ "$vf_found" -ne 1 ]]; then
        warn "Forced VF ${first_entry} did not leave an exact final VF type marker in ${ir_path}; continuing because late vector passes may rewrite the final IR"
    fi
}

validate_vplan_use_vf() {
    local value="$1"
    local entry
    local kind
    local width

    [[ -z "$value" ]] && return 0

    IFS=',' read -r -a entries <<< "$value"
    for entry in "${entries[@]}"; do
        if [[ "$entry" == "-" ]]; then
            continue
        fi
        if [[ ! "$entry" =~ ^(fixed|scalable):([0-9]+)$ ]]; then
            die "USE_VF must match LLVM -vplan-use-vf syntax (e.g. fixed:4,-,scalable:2)"
        fi
        kind="${BASH_REMATCH[1]}"
        width="${BASH_REMATCH[2]}"
        if (( width <= 0 || (width & (width - 1)) != 0 )); then
            die "USE_VF widths must be positive powers of two"
        fi
    done
}

[[ $# -lt 2 ]] && usage

TARGET="$1"
SOURCE="$2"
shift 2

LMUL=1
LEN_1D=1000
USE_VF=""
ASM=0
LLVM_FLAGS=""
EXTRA_CFLAGS=""
OUTPUT=""

while [[ $# -gt 0 ]]; do
    case $1 in
        --lmul=*) LMUL="${1#*=}" ;;
        --len=*) LEN_1D="${1#*=}" ;;
        --use-vf=*) USE_VF="${1#*=}" ;;
        --output=*) OUTPUT="${1#*=}" ;;
        --asm) ASM=1 ;;
        --llvm=*) LLVM_FLAGS="${1#*=}" ;;
        --cflags=*) EXTRA_CFLAGS="${1#*=}" ;;
        *) echo "Unknown option: $1"; usage ;;
    esac
    shift
done

validate_positive_int "LMUL" "$LMUL"
validate_positive_int "LEN_1D" "$LEN_1D"
if [[ -n "$USE_VF" ]]; then
    validate_vplan_use_vf "$USE_VF"
fi

TARGET_FILE="${SCRIPT_DIR}/targets/${TARGET}.sh"
[[ ! -f "$TARGET_FILE" ]] && die "Unknown target: $TARGET"
source "$TARGET_FILE"

KERNEL="$(basename "$SOURCE" .c)"
TSVC_MODE=0
GENERATED_MODE=0
TSVC_LOOP_SOURCE=""
if [[ -f "$SOURCE" ]] && grep -q "${TSVC_WRAPPER_MARKER}" "$SOURCE"; then
    TSVC_MODE=1
    TSVC_LOOP_SOURCE="${SCRIPT_DIR}/../benchmarks/TSVC_2/src/loops/${KERNEL}.c"
    [[ ! -f "$TSVC_LOOP_SOURCE" ]] && die "TSVC loop source not found: $TSVC_LOOP_SOURCE"
elif [[ -f "$SOURCE" ]] && grep -q "${TSVC_GENERATED_MARKER}" "$SOURCE"; then
    GENERATED_MODE=1
fi
OUT_DIR="${SCRIPT_DIR}/out"
mkdir -p "$OUT_DIR"
if [[ -z "$OUTPUT" ]]; then
    VF_SUFFIX=""
    if [[ -n "$USE_VF" ]]; then
        VF_SUFFIX="_vf${USE_VF}"
    fi
    OUTPUT="${OUT_DIR}/${KERNEL}_${TARGET}_lmul${LMUL}${VF_SUFFIX}.elf"
fi

COMMON_FLAGS=(
    -march="${TARGET_ARCH}"
    -mabi="${TARGET_ABI}"
    -mcmodel=medany
    -static
    -nostdlib
    -fno-builtin
    -fno-common
    -DLMUL="${LMUL}"
    -DLEN_1D="${LEN_1D}"
    -I"${SCRIPT_DIR}/common"
)
if [[ "$TSVC_MODE" -eq 1 ]]; then
    COMMON_FLAGS+=(
        -I"${SCRIPT_DIR}/../benchmarks/TSVC_2/src"
        -DTSVC_MEASURE_CYCLES
    )
elif [[ "$GENERATED_MODE" -eq 1 ]]; then
    COMMON_FLAGS+=(
        -I"${SCRIPT_DIR}/../benchmarks/TSVC_2/src"
    )
fi

append_split_flags "${TARGET_CC_FLAGS:-}" COMMON_FLAGS
if [[ "${TARGET_VLEN:-128}" -gt 0 ]]; then
    COMMON_FLAGS+=(-mllvm "-riscv-v-register-bit-width-lmul=${LMUL}")
fi
append_split_flags "$LLVM_FLAGS" COMMON_FLAGS
append_split_flags "$EXTRA_CFLAGS" COMMON_FLAGS

LINK_FLAGS=("${COMMON_FLAGS[@]}" -fuse-ld=lld)
LINK_ARGS=()
if [[ -n "${TARGET_LD:-}" ]]; then
    LINK_ARGS+=(-T"${SCRIPT_DIR}/${TARGET_LD}")
fi

LINK_LIBS=()
SUPPORT_SRCS=()

if [[ "${TARGET_NIX:-0}" == "1" ]]; then
    CC_PATH="$(nix --extra-experimental-features 'nix-command flakes' build "${TARGET_T1_ROOT}/t1#rv32-stdenv.cc" --no-link --print-out-paths 2>/dev/null)"
    CC="${CC_PATH}/bin/riscv32-none-elf-clang"
    EMURT_PATH="$(nix --extra-experimental-features 'nix-command flakes' build "${TARGET_T1_ROOT}/t1#emurt" --no-link --print-out-paths 2>/dev/null)"
    COMPILE_FLAGS=("${COMMON_FLAGS[@]}" -I"${EMURT_PATH}/include")
    LINK_FLAGS+=(-I"${EMURT_PATH}/include")
    LINK_LIBS+=(-L"${EMURT_PATH}/lib" -lemurt)
    SUPPORT_SRCS=(
        "${TARGET_T1_ROOT}/t1/tests/t1_main.S"
        "${SCRIPT_DIR}/common/arrays.c"
        "${SCRIPT_DIR}/common/harness_t1.c"
    )
else
    CC="${TARGET_CC}"
    COMPILE_FLAGS=("${COMMON_FLAGS[@]}")
    if [[ "$TARGET" == "saturn" || "$TARGET" == "ara" || "$TARGET" == "ocelot" ]]; then
        HARNESS="${SCRIPT_DIR}/common/harness_rtl.c"
    elif [[ "$TARGET" == "xiangshan" ]]; then
        HARNESS="${SCRIPT_DIR}/common/harness_xiangshan.c"
    elif [[ "$TARGET" == "vicuna" ]]; then
        HARNESS="${SCRIPT_DIR}/common/harness_vicuna.c"
    elif [[ "$TARGET" == "gem5" ]]; then
        HARNESS="${SCRIPT_DIR}/common/harness_gem5.c"
    else
        HARNESS="${SCRIPT_DIR}/common/harness.c"
    fi
    SUPPORT_SRCS=(
        "${SCRIPT_DIR}/${TARGET_CRT}"
        "${SCRIPT_DIR}/common/arrays.c"
        "${HARNESS}"
    )
fi

if [[ "$TSVC_MODE" -eq 1 ]]; then
    if [[ "${TARGET_NIX:-0}" == "1" ]]; then
        SUPPORT_SRCS=(
            "${TARGET_T1_ROOT}/t1/tests/t1_main.S"
            "${SCRIPT_DIR}/common/harness_t1.c"
        )
    else
        SUPPORT_SRCS=(
            "${SCRIPT_DIR}/${TARGET_CRT}"
            "${HARNESS}"
        )
    fi
    SUPPORT_SRCS+=(
        "${SCRIPT_DIR}/common/tsvc_runtime.c"
        "${SCRIPT_DIR}/../benchmarks/TSVC_2/src/common.c"
        "${SCRIPT_DIR}/../benchmarks/TSVC_2/src/data.c"
        "${SCRIPT_DIR}/../benchmarks/TSVC_2/src/dummy.c"
    )
elif [[ "$GENERATED_MODE" -eq 1 ]]; then
    SUPPORT_SRCS+=(
        "${SCRIPT_DIR}/common/tsvc_runtime.c"
    )
fi

OBJECT_COMPILE_FLAGS=("${COMPILE_FLAGS[@]}" -O3)

if [[ "$ASM" == "1" && -z "$USE_VF" ]]; then
    ASM_OUT="${OUTPUT%.elf}.s"
    ASM_SOURCE="$SOURCE"
    if [[ "$TSVC_MODE" -eq 1 ]]; then
        ASM_SOURCE="$TSVC_LOOP_SOURCE"
    fi
    "${CC}" "${OBJECT_COMPILE_FLAGS[@]}" -S -o "$ASM_OUT" "$ASM_SOURCE"
    echo "Assembly: $ASM_OUT"
    grep -E "vsetvli" "$ASM_OUT" | head -3 || true
    exit 0
fi

if [[ -z "$USE_VF" ]]; then
    SRCS=("${SUPPORT_SRCS[@]}" "${SOURCE}")
    if [[ "$TSVC_MODE" -eq 1 ]]; then
        SRCS+=("${TSVC_LOOP_SOURCE}")
    fi
    echo "Building: $KERNEL (target=$TARGET, lmul=$LMUL)"
    LINK_CMD=("${CC}" -O3 "${LINK_FLAGS[@]}")
    if [[ ${#LINK_ARGS[@]} -gt 0 ]]; then
        LINK_CMD+=("${LINK_ARGS[@]}")
    fi
    LINK_CMD+=("${SRCS[@]}")
    if [[ ${#LINK_LIBS[@]} -gt 0 ]]; then
        LINK_CMD+=("${LINK_LIBS[@]}")
    fi
    LINK_CMD+=(-o "$OUTPUT")
    "${LINK_CMD[@]}"
    echo "Output: $OUTPUT"
    exit 0
fi

OPT_BIN="$(resolve_opt)" || die "opt not found. Set OPT or ensure an LLVM build with opt is available."
BASE_PATH="${OUTPUT%.elf}"
RAW_LL="${BASE_PATH}.raw.ll"
PREVEC_LL="${BASE_PATH}.prevec.ll"
OPT_LL="${BASE_PATH}.opt.ll"
OPT_LOG="${BASE_PATH}.opt.log"
BUILD_DIR="${BASE_PATH}.build"
mkdir -p "$BUILD_DIR"

echo "Building: $KERNEL (target=$TARGET, lmul=$LMUL, use_vf=$USE_VF)"
echo "Generating raw IR: $RAW_LL"
IR_SOURCE="$SOURCE"
if [[ "$TSVC_MODE" -eq 1 ]]; then
    IR_SOURCE="$TSVC_LOOP_SOURCE"
fi
"${CC}" "${COMPILE_FLAGS[@]}" -O0 -Xclang -disable-O0-optnone -S -emit-llvm "$IR_SOURCE" -o "$RAW_LL"

echo "Canonicalizing pre-vector IR: $PREVEC_LL"
"${OPT_BIN}" -passes="${PREVEC_PASSES}" -S "$RAW_LL" -o "$PREVEC_LL"

echo "Running forced-VF optimization: $OPT_LL"
if ! "${OPT_BIN}" \
    -pass-remarks=loop-vectorize \
    -pass-remarks-missed=loop-vectorize \
    -pass-remarks-analysis=loop-vectorize \
    -passes="${FORCED_OPT_PASSES}" \
    -vplan-use-vf="${USE_VF}" \
    -S "$RAW_LL" \
    -o "$OPT_LL" >"$OPT_LOG" 2>&1; then
    cat "$OPT_LOG" >&2
    die "Forced VF optimization failed. Log: $OPT_LOG"
fi

verify_forced_vector_ir "$OPT_LL" "$USE_VF" "$OPT_LOG"

ASM_OUT="${BASE_PATH}.s"
"${CC}" "${OBJECT_COMPILE_FLAGS[@]}" -S "$OPT_LL" -o "$ASM_OUT"
echo "Assembly: $ASM_OUT"
grep -E "vsetvli" "$ASM_OUT" | head -3 || true

if [[ "$ASM" == "1" ]]; then
    exit 0
fi

OBJECTS=()
for src in "${SUPPORT_SRCS[@]}"; do
    obj="${BUILD_DIR}/$(basename "${src%.*}").o"
    compile_to_object "$src" "$obj"
    OBJECTS+=("$obj")
done

if [[ "$TSVC_MODE" -eq 1 ]]; then
    WRAPPER_OBJ="${BUILD_DIR}/${KERNEL}.wrapper.o"
    compile_to_object "$SOURCE" "$WRAPPER_OBJ"
    OBJECTS+=("$WRAPPER_OBJ")
fi

KERNEL_OBJ="${BUILD_DIR}/${KERNEL}.o"
"${CC}" "${OBJECT_COMPILE_FLAGS[@]}" -c "$OPT_LL" -o "$KERNEL_OBJ"
OBJECTS+=("$KERNEL_OBJ")

LINK_CMD=("${CC}" "${LINK_FLAGS[@]}")
if [[ ${#LINK_ARGS[@]} -gt 0 ]]; then
    LINK_CMD+=("${LINK_ARGS[@]}")
fi
LINK_CMD+=("${OBJECTS[@]}")
if [[ ${#LINK_LIBS[@]} -gt 0 ]]; then
    LINK_CMD+=("${LINK_LIBS[@]}")
fi
LINK_CMD+=(-o "$OUTPUT")
"${LINK_CMD[@]}"
echo "Output: $OUTPUT"
echo "Artifacts: $RAW_LL $PREVEC_LL $OPT_LL $OPT_LOG $ASM_OUT"
